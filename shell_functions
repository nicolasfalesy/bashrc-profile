# ── killport: kill process on a specific port ──────────────────────────
killport() {
    case "$1" in
        -h|--help|-H)
            cat <<'EOF'
Kill the process listening on a specific port.

Usage: killport <port> [port...]

Options:
  -h, --help, -H   Show this help message

Examples:
  killport 3000          Kill whatever is on port 3000
  killport 3000 8080     Kill processes on both ports
EOF
            return 0
            ;;
        "")
            echo "Error: port number required" >&2
            return 1
            ;;
    esac

    local p pid
    for p in "$@"; do
        if ! [[ "$p" =~ ^[0-9]+$ ]]; then
            echo "Error: '$p' is not a valid port number" >&2
            continue
        fi
        pid=$(sudo ss -tlnp "sport = :$p" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | head -1)
        if [ -z "$pid" ]; then
            echo "No process found on port $p"
        else
            local name
            name=$(ps -p "$pid" -o comm= 2>/dev/null)
            sudo kill "$pid" && echo "Killed $name (PID $pid) on port $p"
        fi
    done
}

_killport_completions() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    if [[ "$cur" == -* ]]; then
        COMPREPLY=($(compgen -W "-h --help -H" -- "$cur"))
    fi
}
complete -F _killport_completions killport
