# ── dsv: delete files from zpool status output ──────────────────────
dsv() {
  local dry_run=0
  local pattern=""
  local arg

  for arg in "$@"; do
    case "$arg" in
      -h|--help|-H)
        cat <<'HELPEOF'
dsv - Delete files listed in zpool status output

Usage: dsv [OPTIONS] [PATTERN]

Scans `zpool status -v porsche` for file paths matching PATTERN,
then removes them with `rm -v`.

Options:
  -n          Dry run — show files that would be deleted, but don't delete
  -h, --help  Show this help message

Arguments:
  PATTERN     Grep pattern to match (default: /mnt/porsche/)

Examples:
  dsv                        # Remove all files under /mnt/porsche/
  dsv /mnt/porsche/movies    # Remove only files matching /mnt/porsche/movies
  dsv -n                     # Dry run with default pattern
  dsv -n /mnt/porsche/tv     # Dry run for /mnt/porsche/tv
  dsv /mnt/porsche/music -n  # Flags work in any order
HELPEOF
        return 0
        ;;
      -n)
        dry_run=1
        ;;
      -*)
        printf "dsv: unknown option '%s'\n" "$arg" >&2
        printf "Try 'dsv --help' for usage information.\n" >&2
        return 1
        ;;
      *)
        if [[ -n "$pattern" ]]; then
          printf "dsv: unexpected argument '%s' (pattern already set to '%s')\n" "$arg" "$pattern" >&2
          return 1
        fi
        pattern="$arg"
        ;;
    esac
  done

  if [[ -z "$pattern" ]]; then
    pattern="/mnt/porsche/"
  fi

  if ! command -v zpool &>/dev/null; then
    printf "dsv: zpool command not found\n" >&2
    return 1
  fi

  local tmpfile
  tmpfile="$(mktemp)" || { printf "dsv: failed to create temp file\n" >&2; return 1; }

  sudo zpool status -v porsche 2>/dev/null | grep "$pattern" | sed 's/^ *//' > "$tmpfile"

  local count
  count="$(wc -l < "$tmpfile")"
  count="$(echo "$count" | tr -d '[:space:]')"

  if [[ "$count" -eq 0 ]]; then
    printf "dsv: no files found matching '%s'\n" "$pattern"
    rm -f "$tmpfile"
    return 0
  fi

  if [[ "$dry_run" -eq 1 ]]; then
    printf "[DRY RUN] %s file(s) would be removed:\n" "$count"
    while IFS= read -r file; do
      printf "  %s\n" "$file"
    done < "$tmpfile"
  else
    printf "%s file(s) found matching '%s':\n" "$count" "$pattern"
    while IFS= read -r file; do
      printf "  %s\n" "$file"
    done < "$tmpfile"
    printf "\nAre you sure you want to permanently delete these %s file(s)? [y/N] " "$count"
    local confirm
    read -r confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
      printf "Aborted.\n"
      rm -f "$tmpfile"
      return 0
    fi
    printf "Removing %s file(s) matching '%s'...\n" "$count" "$pattern"
    local removed
    local failed
    removed=0
    failed=0

    while IFS= read -r file; do
      if [[ -e "$file" ]]; then
        if command rm -v "$file"; then
          removed=$((removed + 1))
        else
          failed=$((failed + 1))
        fi
      else
        printf "dsv: file not found, skipping: %s\n" "$file" >&2
        failed=$((failed + 1))
      fi
    done < "$tmpfile"

    printf "\nSummary: %s removed, %s failed/skipped out of %s found\n" "$removed" "$failed" "$count"
    if [[ "$removed" -gt 0 ]]; then
      printf "Clearing errors on porsche...\n"
      sudo zpool clear porsche && printf "Pool errors cleared.\n"
    fi
  fi
  rm -f "$tmpfile"
}

_dsv_completions() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    if [[ "$cur" == -* ]]; then
        COMPREPLY=($(compgen -W "-h --help -H -n" -- "$cur"))
    else
        COMPREPLY=($(compgen -W "/mnt/porsche/ /mnt/porsche/movies /mnt/porsche/tv /mnt/porsche/music" -- "$cur"))
    fi
}
complete -F _dsv_completions dsv

# ── t: tmux session manager ────────────────────────────────────────────
t() {
    case "$1" in
        -h|--help|-H|"")
            cat <<'EOF'
Tmux session manager.

Usage: t <option> [name]

Options:
  -n <name>        Create (or attach to) a named session
  -a <name>        Attach to an existing session
  -p <name>        Purge (kill) a session
  -l               List all sessions
  -k               Kill the tmux server (all sessions)
  -h, --help, -H   Show this help message

Examples:
  t -n dev         Create or attach to session "dev"
  t -a dev         Attach to existing session "dev"
  t -p dev         Kill session "dev"
  t -l             List all sessions
  t -k             Kill all tmux sessions
EOF
            return 0
            ;;
        -n)
            if [ -z "$2" ]; then
                echo "Error: session name required" >&2
                return 1
            fi
            if tmux has-session -t "$2" 2>/dev/null; then
                tmux attach-session -t "$2"
            else
                tmux new-session -s "$2"
            fi
            ;;
        -a)
            if [ -z "$2" ]; then
                echo "Error: session name required" >&2
                return 1
            fi
            tmux attach-session -t "$2" 2>/dev/null || {
                echo "Error: session '$2' not found" >&2
                return 1
            }
            ;;
        -p)
            if [ -z "$2" ]; then
                echo "Error: session name required" >&2
                return 1
            fi
            tmux kill-session -t "$2" 2>/dev/null || {
                echo "Error: session '$2' not found" >&2
                return 1
            }
            echo "Killed session '$2'"
            ;;
        -l)
            tmux list-sessions 2>/dev/null || echo "No tmux sessions running."
            ;;
        -k)
            tmux kill-server 2>/dev/null || echo "No tmux server running."
            echo "All tmux sessions killed."
            ;;
        *)
            # Bare name — create or attach
            if tmux has-session -t "$1" 2>/dev/null; then
                tmux attach-session -t "$1"
            else
                tmux new-session -s "$1"
            fi
            ;;
    esac
}

_t_completions() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local prev="${COMP_WORDS[COMP_CWORD-1]}"

    case "$prev" in
        -n|-a|-p)
            local sessions
            sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null)
            COMPREPLY=($(compgen -W "$sessions" -- "$cur"))
            return
            ;;
    esac

    if [[ "$cur" == -* ]]; then
        COMPREPLY=($(compgen -W "-h --help -H -n -a -p -l -k" -- "$cur"))
    else
        local sessions
        sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null)
        COMPREPLY=($(compgen -W "$sessions" -- "$cur"))
    fi
}
complete -F _t_completions t

# ── topp: top processes by CPU or memory ───────────────────────────────
topp() {
    local count=10
    case "$1" in
        -h|--help|-H)
            cat <<'EOF'
Show top processes sorted by CPU or memory usage.

Usage: topp [option] [count]

Options:
  -c, --cpu        Sort by CPU usage (default)
  -m, --mem        Sort by memory usage
  -h, --help, -H   Show this help message

Examples:
  topp               Top 10 by CPU
  topp -m            Top 10 by memory
  topp -c 20         Top 20 by CPU
  topp -m 5          Top 5 by memory
EOF
            return 0
            ;;
        -m|--mem)
            shift
            [ -n "$1" ] && count="$1"
            echo -e "\033[0;34m--- Top $count processes by memory ---\033[0m"
            ps aux --sort=-%mem | head -n $(( count + 1 ))
            ;;
        -c|--cpu)
            shift
            [ -n "$1" ] && count="$1"
            echo -e "\033[0;34m--- Top $count processes by CPU ---\033[0m"
            ps aux --sort=-%cpu | head -n $(( count + 1 ))
            ;;
        ""|[0-9]*)
            [ -n "$1" ] && count="$1"
            echo -e "\033[0;34m--- Top $count processes by CPU ---\033[0m"
            ps aux --sort=-%cpu | head -n $(( count + 1 ))
            ;;
    esac
}

